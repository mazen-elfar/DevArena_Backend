{
  "name": "devarena-backend",
  "version": "1.0.0",
  "description": "DevArena REST API + WebSocket server",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node src/database/seeds/index.js",
    "db:generate": "prisma generate",
    "lint": "eslint src --ext .js",
    "format": "prettier --write src"
  },
  "dependencies": {
    "express": "^5.0.0",
    "@prisma/client": "^5.14.0",
    "ioredis": "^5.3.2",
    "bullmq": "^5.7.0",
    "socket.io": "^4.7.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.8",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "express-rate-limit": "^7.3.1",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.3",
    "prisma": "^5.14.0",
    "eslint": "^9.5.0",
    "prettier": "^3.3.2"
  }
}