// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════
// AUTHENTICATION & ROLES
// ═══════════════════════════════════════════

model User {
  id            String       @id @default(uuid()) @db.Uuid
  email         String       @unique @db.VarChar(255)
  passwordHash  String?      @map("password_hash") @db.VarChar(255)
  provider      AuthProvider @default(LOCAL)
  emailVerified Boolean      @default(false) @map("email_verified")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz()

  // RBAC
  roles       UserRole[]
  permissions UserPermission[]

  // Relations
  profile   Profile?
  providers UserProvider[]

  @@index([createdAt])
  @@map("users")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique @db.VarChar(50) // GUEST, DEVELOPER, PREMIUM, MODERATOR, ADMIN, SUPERADMIN
  description String?          @db.Text
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @db.VarChar(50) // e.g., "CREATE_POST"
  description String?
  roles       RolePermission[]
  users       UserPermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  userId       String     @map("user_id") @db.Uuid
  permissionId String     @map("permission_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    Int      @map("role_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@id([userId, roleId])
  @@map("user_roles")
}

// ═══════════════════════════════════════════
// SOCIAL IDENTITY PROVIDERS
// ═══════════════════════════════════════════

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
}

model UserProvider {
  id           String       @id @default(cuid())
  userId       String       @map("user_id") @db.Uuid
  provider     AuthProvider
  providerUid  String       @map("provider_uid") @db.VarChar(255)
  accessToken  String?      @map("access_token") @db.Text
  refreshToken String?      @map("refresh_token") @db.Text
  lastLoginAt  DateTime?    @map("last_login_at") @db.Timestamptz()
  linkedAt     DateTime     @default(now()) @map("linked_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@index([userId])
  @@map("user_providers")
}

// ═══════════════════════════════════════════
// COMMUNITY & SOCIAL
// ═══════════════════════════════════════════

model Profile {
  id          String  @id @default(uuid()) @db.Uuid
  userId      String  @unique @map("user_id") @db.Uuid
  username    String  @unique @db.VarChar(50)
  displayName String? @map("display_name") @db.VarChar(100)
  avatar      String? @db.Text
  banner      String? @db.Text
  bio         String? @db.Text

  // Education
  university     String? @db.VarChar(100)
  major          String? @db.VarChar(100)
  graduationYear Int?    @map("graduation_year")

  // Location
  country String? @db.VarChar(100)
  region  String? @db.VarChar(100)

  // Socials
  githubUsername String? @map("github_username") @db.VarChar(100)
  githubUrl      String? @map("github_url") @db.Text
  linkedinUrl    String? @map("linkedin_url") @db.Text
  portfolioUrl   String? @map("portfolio_url") @db.Text
  websiteUrl     String? @map("website_url") @db.Text

  // Stats (Denormalized)
  level      Int    @default(1)
  currentXP  BigInt @default(0) @map("current_xp")
  totalXP    BigInt @default(0) @map("total_xp")
  rating     Int    @default(1000)
  reputation Int    @default(0)

  // Flags
  profileCompleted Boolean @default(false) @map("profile_completed")
  isVerified       Boolean @default(false) @map("is_verified")
  isOnline         Boolean @default(false) @map("is_online")

  // Relations
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reputationScores Reputation?
  skills           UserSkill[]

  // Community Relations
  posts      Post[]         @relation("ProfilePosts")
  comments   Comment[]      @relation("ProfileComments")
  reactions  Reaction[]     @relation("ProfileReactions")
  savedPosts SavedPost[]    @relation("ProfileSavedPosts")
  followers  Follow[]       @relation("Following")
  following  Follow[]       @relation("Follower")
  circles    CircleMember[]
  ownedCircles DeveloperCircle[]

  // Competitive Relations
  submissions             Submission[]
  battlePlayers           BattlePlayer[]
  battleSubmissions       BattleSubmission[]
  wonBattles              Battle[]
  bracketPlayer1          Bracket[]           @relation("BracketPlayer1")
  bracketPlayer2          Bracket[]           @relation("BracketPlayer2")
  bracketWins             Bracket[]           @relation("BracketWinner")
  tournamentRegistrations TournamentRegistration[]
  tournamentParticipants  TournamentParticipant[]
  tournamentResults       TournamentResult[]
  rankHistory             UserRankHistory[]
  xpLogs                  XpLog[]
  userAchievements        UserAchievement[]
  coinTransactions        CoinTransaction[]
  streaks                 Streak[]
  organizationMembers     OrganizationMember[]
  teamMemberships         TeamMember[]
  sentInvites             TeamInvite[]        @relation("TeamInviter")
  receivedInvites         TeamInvite[]        @relation("TeamInvitee")
  verificationRequests    VerificationRequest[]
  userTitles              UserTitle[]

  // System
  notifications        Notification[]
  subscriptions        Subscription[]
  matchmakingQueue     MatchmakingQueue[]
  payments             Payment[]
  payouts              Payout[]
  friendshipsRequested Friendship[]              @relation("Requester")
  friendshipsAddressed Friendship[]              @relation("Addressee")
  conversations        ConversationParticipant[]
  messages             Message[]
  reports              Report[]                  @relation("Target")
  reportedBy           Report[]                  @relation("Reporter")
  reviewedReports      Report[]                  @relation("Reviewer")
  verifiedPayouts      Payout[]                  @relation("Verifier")
  adminActions         AdminAction[]             @relation("AdminActionAdmin")
  targetedByAdmin      AdminAction[]             @relation("AdminActionTarget")
  battleEvents       BattleEvent[] @relation("BattleEventUser")
  battleMessages     BattleMessage[]
  detailedRankHistory  RankHistory[]

  @@index([rating])
  @@index([username])
  @@index([level])
  @@map("profiles")
}

// ═══════════════════════════════════════════
// SKILLS SYSTEM
// ═══════════════════════════════════════════

model SkillCategory {
  id     Int     @id @default(autoincrement())
  name   String  @unique @db.VarChar(100) // e.g., Frontend, Backend
  skills Skill[]

  @@map("skill_categories")
}

model Skill {
  id         Int           @id @default(autoincrement())
  categoryId Int           @map("category_id")
  name       String        @unique @db.VarChar(100)
  category   SkillCategory @relation(fields: [categoryId], references: [id])
  users      UserSkill[]

  @@map("skills")
}

model UserSkill {
  profileId       String           @map("profile_id") @db.Uuid
  skillId         Int              @map("skill_id")
  level           ProficiencyLevel @default(BEGINNER)
  yearsExperience Int              @default(0) @map("years_experience")
  isVerified      Boolean          @default(false) @map("is_verified")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([profileId, skillId])
  @@map("user_skills")
}

enum ProficiencyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
  PROFESSIONAL
}

model Post {
  id            String    @id @default(uuid()) @db.Uuid
  authorId      String    @map("author_id") @db.Uuid
  type          PostType  @default(TEXT)
  title         String?   @db.VarChar(255)
  content       String    @db.Text
  reactionCount Int       @default(0) @map("reaction_count")
  commentCount  Int       @default(0) @map("comment_count")
  saveCount     Int       @default(0) @map("save_count")
  isPublished   Boolean   @default(true) @map("is_published")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz()

  author    Profile     @relation("ProfilePosts", fields: [authorId], references: [id])
  comments  Comment[]
  reactions Reaction[]
  savedBy   SavedPost[]

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@index([type])
  @@map("posts")
}

enum PostType {
  TEXT
  ACHIEVEMENT
  BATTLE_RESULT
  QUEST_COMPLETION
  TOURNAMENT_RESULT
  PROJECT_SHOWCASE
  DISCUSSION
}

model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  content   String   @db.Text
  parentId  String?  @map("parent_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  Profile   @relation("ProfileComments", fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([postId, createdAt])
  @@index([authorId])
  @@map("comments")
}

model Reaction {
  userId    String       @map("user_id") @db.Uuid
  postId    String       @map("post_id") @db.Uuid
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  user Profile @relation("ProfileReactions", fields: [userId], references: [id], onDelete: Cascade)
  post Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("reactions")
}

enum ReactionType {
  LIKE
  LOVE
  FIRE
  MIND_BLOWN
  ROCKET
}

model SavedPost {
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user Profile @relation("ProfileSavedPosts", fields: [userId], references: [id], onDelete: Cascade)
  post Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("saved_posts")
}

model Follow {
  followerId  String       @map("follower_id") @db.Uuid
  followingId String       @map("following_id") @db.Uuid
  status      FollowStatus @default(FOLLOWING)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  follower  Profile @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following Profile @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

enum FollowStatus {
  FOLLOWING
  REQUESTED
  BLOCKED
}

// ═══════════════════════════════════════════
// DEVELOPER CIRCLES
// ═══════════════════════════════════════════

model DeveloperCircle {
  id      String         @id @default(uuid()) @db.Uuid
  ownerId String         @map("owner_id") @db.Uuid
  name    String         @db.VarChar(50) // e.g., Friends, Mentors, Rivals
  color   String?        @db.VarChar(7)
  owner   Profile        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members CircleMember[]

  @@map("developer_circles")
}

model CircleMember {
  circleId  String          @map("circle_id") @db.Uuid
  profileId String          @map("profile_id") @db.Uuid
  circle    DeveloperCircle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  profile   Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([circleId, profileId])
  @@map("circle_members")
}

// ═══════════════════════════════════════════
// SOCIAL — FRIENDS
// ═══════════════════════════════════════════

model Friendship {
  id          String           @id @default(uuid()) @db.Uuid
  requesterId String           @map("requester_id") @db.Uuid
  addresseeId String           @map("addressee_id") @db.Uuid
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  requester Profile @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee Profile @relation("Addressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@index([addresseeId, status])
  @@index([requesterId, status])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ═══════════════════════════════════════════
// MESSAGING
// ═══════════════════════════════════════════

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  joinedAt       DateTime  @default(now()) @map("joined_at") @db.Timestamptz()
  lastReadAt     DateTime? @map("last_read_at") @db.Timestamptz()
  isMuted        Boolean   @default(false) @map("is_muted")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  profile      Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  content        String   @db.Text
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Profile      @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
  @@map("messages")
}

// ═══════════════════════════════════════════
// QUESTS & SUBMISSIONS
// ═══════════════════════════════════════════

model QuestCategory {
  id          Int     @id @default(autoincrement())
  name        String  @unique @db.VarChar(100)
  description String? @db.Text
  slug        String  @unique @db.VarChar(100)
  sortOrder   Int     @default(0) @map("sort_order")

  quests Quest[]

  @@map("quest_categories")
}

model Quest {
  id            String          @id @default(uuid()) @db.Uuid
  categoryId    Int             @map("category_id")
  title         String          @db.VarChar(255)
  description   String          @db.Text
  difficulty    QuestDifficulty
  xpReward      Int             @map("xp_reward")
  coinsReward   Int             @default(0) @map("coins_reward")
  examples      Json?           @db.JsonB
  constraints   String?         @db.Text
  testTemplate  String?         @map("test_template") @db.Text
  timeLimitMs   Int             @default(5000) @map("time_limit_ms")
  memoryLimitMb Int             @default(256) @map("memory_limit_mb")
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz()

  category    QuestCategory @relation(fields: [categoryId], references: [id])
  testCases   TestCase[]
  submissions Submission[]
  battles     Battle[]

  @@index([categoryId, difficulty])
  @@index([difficulty])
  @@index([isActive])
  @@map("quests")
}

enum QuestDifficulty {
  EASY
  MEDIUM
  HARD
  LEGENDARY
}

model TestCase {
  id             String  @id @default(uuid()) @db.Uuid
  questId        String  @map("quest_id") @db.Uuid
  inputData      String  @map("input_data") @db.Text
  expectedOutput String  @map("expected_output") @db.Text
  isHidden       Boolean @default(false) @map("is_hidden")
  weight         Int     @default(1)
  sortOrder      Int     @default(0) @map("sort_order")

  quest Quest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@index([questId])
  @@map("test_cases")
}

model Submission {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  questId     String              @map("quest_id") @db.Uuid
  language    ProgrammingLanguage
  sourceCode  String              @map("source_code") @db.Text
  status      SubmissionStatus    @default(PENDING)
  runtimeMs   Int?                @map("runtime_ms")
  memoryKb    Int?                @map("memory_kb")
  testResults Json?               @map("test_results") @db.JsonB
  submittedAt DateTime            @default(now()) @map("submitted_at") @db.Timestamptz()

  user  Profile @relation(fields: [userId], references: [id])
  quest Quest   @relation(fields: [questId], references: [id])

  @@index([userId, questId])
  @@index([questId, status])
  @@index([submittedAt(sort: Desc)])
  @@map("submissions")
}

enum ProgrammingLanguage {
  JAVASCRIPT
  TYPESCRIPT
  PYTHON
  JAVA
  CPP
  CSHARP
  GO
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  COMPILATION_ERROR
  MEMORY_LIMIT_EXCEEDED
}

// ═══════════════════════════════════════════
// DEVBATTLE
// ═══════════════════════════════════════════

model Battle {
  id           String        @id @default(uuid()) @db.Uuid
  mode         BattleMode
  questId      String        @map("quest_id") @db.Uuid
  status       BattleStatus  @default(WAITING)
  winnerId     String?       @map("winner_id") @db.Uuid
  aiDifficulty AiDifficulty? @map("ai_difficulty")
  timeLimitSec Int           @default(300) @map("time_limit_sec")
  startedAt    DateTime?     @map("started_at") @db.Timestamptz()
  endedAt      DateTime?     @map("ended_at") @db.Timestamptz()
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  quest             Quest              @relation(fields: [questId], references: [id])
  winner            Profile?           @relation(fields: [winnerId], references: [id], onDelete: SetNull)
  players           BattlePlayer[]
  battleSubmissions BattleSubmission[]
  brackets          Bracket[]
  events            BattleEvent[]
  messages          BattleMessage[]

  @@index([status])
  @@index([mode])
  @@index([createdAt(sort: Desc)])
  @@index([questId])
  @@index([winnerId])
  @@map("battles")
}

enum BattleMode {
  RANKED
  CLASSIC
  FRIEND
  AI
}

enum BattleStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AiDifficulty {
  EASY
  MEDIUM
  HARD
}

model BattlePlayer {
  id       String   @id @default(uuid()) @db.Uuid
  battleId String   @map("battle_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  isWinner Boolean  @default(false) @map("is_winner")
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz()

  battle Battle  @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user   Profile @relation(fields: [userId], references: [id])

  @@unique([battleId, userId])
  @@index([userId])
  @@map("battle_players")
}

model BattleSubmission {
  id          String              @id @default(uuid()) @db.Uuid
  battleId    String              @map("battle_id") @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  sourceCode  String              @map("source_code") @db.Text
  language    ProgrammingLanguage
  status      SubmissionStatus    @default(PENDING)
  runtimeMs   Int?                @map("runtime_ms")
  testResults Json?               @map("test_results") @db.JsonB
  submittedAt DateTime            @default(now()) @map("submitted_at") @db.Timestamptz()

  battle Battle  @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user   Profile @relation(fields: [userId], references: [id])

  @@index([battleId])
  @@index([userId])
  @@index([battleId, userId])
  @@map("battle_submissions")
}

model BattleEvent {
  id        String   @id @default(uuid()) @db.Uuid
  battleId  String   @map("battle_id") @db.Uuid
  type      String   @db.VarChar(50)
  userId    String?  @map("user_id") @db.Uuid
  data      Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  battle Battle  @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user   Profile? @relation("BattleEventUser", fields: [userId], references: [id])

  @@index([battleId, createdAt])
  @@map("battle_events")
}

model BattleMessage {
  id        String   @id @default(uuid()) @db.Uuid
  battleId  String   @map("battle_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  battle Battle  @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user   Profile @relation(fields: [userId], references: [id])

  @@index([battleId, createdAt])
  @@map("battle_messages")
}

model MatchmakingQueue {
  id       String            @id @default(uuid()) @db.Uuid
  userId   String            @map("user_id") @db.Uuid
  rating   Int               @default(1000)
  status   MatchmakingStatus @default(QUEUED)
  joinedAt DateTime          @default(now()) @map("joined_at") @db.Timestamptz()

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, rating])
  @@index([userId])
  @@map("matchmaking_queue")
}

enum MatchmakingStatus {
  QUEUED
  MATCHED
  EXPIRED
}

// ═══════════════════════════════════════════
// RANKING
// ═══════════════════════════════════════════

model Rank {
  id        Int     @id @default(autoincrement())
  name      String  @unique @db.VarChar(50) // Explorer, Builder, Engineer, Architect, Master, Legend, Immortal
  minRating Int     @map("min_rating")
  maxRating Int     @map("max_rating")
  color     String  @db.VarChar(7)
  iconUrl   String? @map("icon_url") @db.Text
  order     Int

  userRankHistory UserRankHistory[]

  @@index([minRating, maxRating])
  @@map("ranks")
}

model RankHistory {
  id        String   @id @default(uuid()) @db.Uuid
  profileId String   @map("profile_id") @db.Uuid
  oldRank   String   @map("old_rank")
  newRank   String   @map("new_rank")
  oldRating Int      @map("old_rating")
  newRating Int      @map("new_rating")
  reason    String   @db.VarChar(255) // Battle Win, Battle Loss, Tournament Result
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt(sort: Desc)])
  @@map("rank_history")
}

// ═══════════════════════════════════════════
// TOURNAMENTS
// ═══════════════════════════════════════════

model Tournament {
  id          String           @id @default(uuid()) @db.Uuid
  title       String           @db.VarChar(255)
  description String?          @db.Text
  startDate   DateTime         @map("start_date") @db.Timestamptz()
  endDate     DateTime         @map("end_date") @db.Timestamptz()
  status      TournamentStatus @default(UPCOMING)
  entryFee    Int              @default(0) @map("entry_fee")
  prizePool   String?          @map("prize_pool")

  registrations TournamentRegistration[]
  participants  TournamentParticipant[]
  brackets      Bracket[]
  results       TournamentResult[]

  @@map("tournaments")
}

enum TournamentStatus {
  UPCOMING
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model TournamentRegistration {
  id           String             @id @default(uuid()) @db.Uuid
  tournamentId String             @map("tournament_id") @db.Uuid
  profileId    String             @map("profile_id") @db.Uuid
  status       RegistrationStatus @default(PENDING)
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz()

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  profile    Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, profileId])
  @@map("tournament_registrations")
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model TournamentParticipant {
  id           String @id @default(uuid()) @db.Uuid
  tournamentId String @map("tournament_id") @db.Uuid
  profileId    String @map("profile_id") @db.Uuid
  seed         Int?
  rank         Int?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  profile    Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, profileId])
  @@map("tournament_participants")
}

model TournamentResult {
  id           String  @id @default(uuid()) @db.Uuid
  tournamentId String  @map("tournament_id") @db.Uuid
  profileId    String  @map("profile_id") @db.Uuid
  position     Int
  prizeWon     String? @map("prize_won")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  profile    Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("tournament_results")
}

// ═══════════════════════════════════════════
// ECONOMY & REPUTATION
// ═══════════════════════════════════════════

model Reputation {
  id            String @id @default(uuid()) @db.Uuid
  profileId     String @unique @map("profile_id") @db.Uuid
  contribution  Int    @default(0)
  mentorship    Int    @default(0)
  sportsmanship Int    @default(0)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_reputation")
}

// ═══════════════════════════════════════════
// ORGANIZATIONS & UNIVERSITIES (D15)
// ═══════════════════════════════════════════

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  logo        String?  @db.Text
  country     String?  @db.VarChar(100)
  type        OrgType
  description String?  @db.Text
  websiteUrl  String?  @map("website_url") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  members OrganizationMember[]

  @@map("organizations")
}

enum OrgType {
  UNIVERSITY
  COMPANY
  BOOTCAMP
}

model OrganizationMember {
  organizationId String       @map("organization_id") @db.Uuid
  profileId      String       @map("profile_id") @db.Uuid
  role           OrgMemberRole @default(MEMBER)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profile      Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([organizationId, profileId])
  @@map("organization_members")
}

enum OrgMemberRole {
  STUDENT
  FACULTY
  EMPLOYEE
  MEMBER
}

// ═══════════════════════════════════════════
// DEVELOPER TEAMS (D11)
// ═══════════════════════════════════════════

model Team {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  avatar      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  members TeamMember[]
  invites TeamInvite[]

  @@map("teams")
}

model TeamMember {
  teamId    String   @map("team_id") @db.Uuid
  profileId String   @map("profile_id") @db.Uuid
  role      TeamRole @default(MEMBER)
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz()

  team    Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([teamId, profileId])
  @@map("team_members")
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

model TeamInvite {
  id        String       @id @default(uuid()) @db.Uuid
  teamId    String       @map("team_id") @db.Uuid
  inviterId String       @map("inviter_id") @db.Uuid
  inviteeId String       @map("invitee_id") @db.Uuid
  status    InviteStatus @default(PENDING)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  team    Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter Profile @relation("TeamInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee Profile @relation("TeamInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([inviteeId])
  @@map("team_invites")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

// ═══════════════════════════════════════════
// VERIFICATION SYSTEM (D16)
// ═══════════════════════════════════════════

model VerificationRequest {
  id        String             @id @default(uuid()) @db.Uuid
  profileId String             @map("profile_id") @db.Uuid
  type      VerificationType
  status    VerificationStatus @default(PENDING)
  evidence  Json?              @db.JsonB // Documentation urls, github links etc.
  adminNote String?            @map("admin_note") @db.Text
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("verification_requests")
}

enum VerificationType {
  STUDENT
  PROFESSIONAL
  OPEN_SOURCE
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Bracket {
  id           String        @id @default(uuid()) @db.Uuid
  tournamentId String        @map("tournament_id") @db.Uuid
  round        Int
  matchNumber  Int           @map("match_number")
  player1Id    String?       @map("player1_id") @db.Uuid
  player2Id    String?       @map("player2_id") @db.Uuid
  winnerId     String?       @map("winner_id") @db.Uuid
  battleId     String?       @map("battle_id") @db.Uuid
  status       BracketStatus @default(PENDING)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player1    Profile?   @relation("BracketPlayer1", fields: [player1Id], references: [id], onDelete: SetNull)
  player2    Profile?   @relation("BracketPlayer2", fields: [player2Id], references: [id], onDelete: SetNull)
  winner     Profile?   @relation("BracketWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  battle     Battle?    @relation(fields: [battleId], references: [id], onDelete: SetNull)

  @@index([tournamentId, round])
  @@map("brackets")
}

enum BracketStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Achievement {
  id               Int                 @id @default(autoincrement())
  slug             String              @unique @db.VarChar(100)
  name             String              @db.VarChar(100)
  description      String              @db.Text
  icon             String?             @db.Text
  category         AchievementCategory
  rarity           AchievementRarity   @default(COMMON)
  xpReward         Int                 @default(0) @map("xp_reward")
  reputationReward Int                 @default(0) @map("reputation_reward")
  hidden           Boolean             @default(false)
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz()

  userAchievements UserAchievement[]

  @@map("achievements")
}

enum AchievementCategory {
  COMMUNITY
  QUESTS
  BATTLES
  TOURNAMENTS
  OPEN_SOURCE
  SOCIAL
}

enum AchievementRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

model UserAchievement {
  profileId     String   @map("profile_id") @db.Uuid
  achievementId Int      @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at") @db.Timestamptz()

  profile     Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@id([profileId, achievementId])
  @@map("user_achievements")
}

model Title {
  id          Int         @id @default(autoincrement())
  name        String      @unique @db.VarChar(100)
  description String?     @db.Text
  rarity      TitleRarity @default(COMMON)

  userTitles UserTitle[]

  @@map("titles")
}

enum TitleRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

model UserTitle {
  profileId String  @map("profile_id") @db.Uuid
  titleId   Int     @map("title_id")
  equipped  Boolean @default(false)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title   Title   @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@id([profileId, titleId])
  @@map("user_titles")
}

model Streak {
  id             String     @id @default(uuid()) @db.Uuid
  profileId      String     @map("profile_id") @db.Uuid
  type           StreakType
  currentStreak  Int        @default(0) @map("current_streak")
  longestStreak  Int        @default(0) @map("longest_streak")
  lastActiveDate DateTime   @map("last_active_date") @db.Date

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, type])
  @@map("streaks")
}

enum StreakType {
  DAILY_LOGIN
  DAILY_QUEST
  DAILY_BATTLE
}

model CoinTransaction {
  id            String   @id @default(uuid()) @db.Uuid
  profileId     String   @map("profile_id") @db.Uuid
  amount        Int
  balanceAfter  BigInt   @map("balance_after")
  reason        String   @db.VarChar(255)
  referenceType String?  @map("reference_type") @db.VarChar(50)
  referenceId   String?  @map("reference_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt(sort: Desc)])
  @@map("coin_transactions")
}

// ═══════════════════════════════════════════
// PAYMENTS & SUBSCRIPTIONS
// ═══════════════════════════════════════════

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  profileId      String        @map("profile_id") @db.Uuid
  type           PaymentType
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("USD") @db.VarChar(3)
  status         PaymentStatus @default(PENDING)
  transactionRef String?       @map("transaction_ref") @db.VarChar(255)
  gateway        String?       @db.VarChar(50)
  metadata       Json?         @db.JsonB
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  completedAt    DateTime?     @map("completed_at") @db.Timestamptz()

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt(sort: Desc)])
  @@index([status])
  @@map("payments")
}

enum PaymentType {
  TOURNAMENT_ENTRY
  SUBSCRIPTION
  STORE_PURCHASE
  PRIZE_PAYOUT
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

model Payout {
  id          String        @id @default(uuid()) @db.Uuid
  profileId   String        @map("profile_id") @db.Uuid
  amount      Decimal       @db.Decimal(10, 2)
  status      PayoutStatus  @default(PENDING)
  method      PayoutMethod?
  accountRef  String?       @map("account_ref") @db.VarChar(255)
  verifiedBy  String?       @map("verified_by") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  completedAt DateTime?     @map("completed_at") @db.Timestamptz()

  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  verifier Profile? @relation("Verifier", fields: [verifiedBy], references: [id], onDelete: SetNull)

  @@index([profileId, createdAt(sort: Desc)])
  @@map("payouts")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PayoutMethod {
  BANK
  PAYPAL
  CRYPTO
}

model Subscription {
  id        String             @id @default(uuid()) @db.Uuid
  profileId String             @map("profile_id") @db.Uuid
  plan      SubscriptionPlan
  price     Decimal            @db.Decimal(10, 2)
  status    SubscriptionStatus @default(ACTIVE)
  startsAt  DateTime           @map("starts_at") @db.Timestamptz()
  expiresAt DateTime           @map("expires_at") @db.Timestamptz()
  autoRenew Boolean            @default(true) @map("auto_renew")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, status])
  @@map("subscriptions")
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

// ═══════════════════════════════════════════
// CRITICAL RECOVERY MODELS
// ═══════════════════════════════════════════

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  profileId String   @map("profile_id") @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  message   String   @db.Text
  link      String?  @db.Text
  metadata  Json?    @db.JsonB
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt(sort: Desc)])
  @@map("notifications")
}

model XpLog {
  id          String   @id @default(uuid()) @db.Uuid
  profileId   String   @map("profile_id") @db.Uuid
  amount      Int
  source      String   @db.VarChar(50)
  description String?  @db.Text
  referenceId String?  @map("reference_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, createdAt(sort: Desc)])
  @@map("xp_logs")
}

model UserRankHistory {
  id        String   @id @default(uuid()) @db.Uuid
  profileId String   @map("profile_id") @db.Uuid
  rankId    Int?     @map("rank_id")
  oldRating Int      @map("old_rating")
  newRating Int      @map("new_rating")
  changedAt DateTime @default(now()) @map("changed_at") @db.Timestamptz()

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  rank    Rank?   @relation(fields: [rankId], references: [id], onDelete: SetNull)

  @@index([profileId, changedAt(sort: Desc)])
  @@map("user_rank_history")
}

// ═══════════════════════════════════════════
// STUB MODELS (REQUIRED LATER)
// ═══════════════════════════════════════════

model Report {
  id         String       @id @default(uuid()) @db.Uuid
  reporterId String       @map("reporter_id") @db.Uuid
  targetId   String       @map("target_id") @db.Uuid
  reason     String       @db.Text
  status     ReportStatus @default(OPEN)
  reviewedBy String?      @map("reviewed_by") @db.Uuid
  resolvedAt DateTime?    @map("resolved_at") @db.Timestamptz()
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  reporter Profile @relation("Reporter", fields: [reporterId], references: [id])
  target   Profile @relation("Target", fields: [targetId], references: [id])
  reviewer Profile? @relation("Reviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@map("reports")
}

enum ReportStatus {
  OPEN
  RESOLVED
  REJECTED
}

model AdminAction {
  id           String    @id @default(uuid()) @db.Uuid
  adminId      String    @map("admin_id") @db.Uuid
  targetUserId String    @map("target_user_id") @db.Uuid
  action       String    @db.VarChar(50) // BAN, SUSPEND, MUTE, WARN
  reason       String    @db.Text
  durationHrs  Int?      @map("duration_hours")
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  admin      Profile @relation("AdminActionAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  targetUser Profile @relation("AdminActionTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@map("admin_actions")
}
